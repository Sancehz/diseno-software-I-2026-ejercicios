{
  "name": "moto-parts-marketplace",
  "version": "1.0.0",
  "description": "API serverless para mercado de intercambio de partes de motos",
  "main": "index.js",
  "scripts": {
    "dev": "serverless offline start",
    "deploy:prod": "serverless deploy --stage prod",
    "dynamodb:install": "serverless dynamodb install",
    "dynamodb:start": "serverless dynamodb start",
    "seed": "node scripts/seed.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1029.0",
    "@aws-sdk/lib-dynamodb": "^3.1029.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "serverless": "^4.34.0",
    "serverless-dynamodb-local": "^0.2.40",
    "serverless-offline": "^14.5.0"
  }
}
